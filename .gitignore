# ==========================================
# OS Development .gitignore
# ==========================================

# Ignore compiled object files and assembly binaries
*.o
*.bin
*.elf

# Ignore final bootable disk images
*.iso
*.img

# Ignore the build directories where temporary files go
build/
obj/

# Ignore host-specific IDE files (like VS Code settings)
.vscode/

# Ignore log files generated by QEMU
*.log